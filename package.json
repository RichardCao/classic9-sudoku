{
  "name": "@sudoku-tools/classic9",
  "version": "0.5.0",
  "private": false,
  "type": "module",
  "description": "标准 9x9 Sudoku TypeScript 工具库：解析、校验、可解释求解、评分、生成、canonical 去重、候选池和 CLI。",
  "author": "Cao Ruichuang",
  "license": "MIT",
  "homepage": "https://github.com/RichardCao/classic9-sudoku#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RichardCao/classic9-sudoku.git"
  },
  "bugs": {
    "url": "https://github.com/RichardCao/classic9-sudoku/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "sideEffects": false,
  "keywords": [
    "sudoku",
    "sudoku-solver",
    "sudoku-generator",
    "sudoku-rating",
    "sudoku-hints",
    "sudoku-cli",
    "sudoku-canonical",
    "classic9",
    "canonical",
    "logic-puzzle",
    "logic-solver",
    "puzzle",
    "puzzle-generator",
    "typescript"
  ],
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist/src",
    "README.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "docs/API.md",
    "docs/BROWSER_USAGE.md",
    "docs/CANDIDATE_POOL.md",
    "docs/CANONICAL.md",
    "docs/COMPATIBILITY.md",
    "docs/GENERATOR.md",
    "docs/GENERATOR_COOKBOOK.md",
    "docs/MIGRATING_FROM_POPULAR_PACKAGES.md",
    "docs/MIGRATING_FROM_SIMPLE_SUDOKU_PACKAGES.md",
    "docs/MINIMAL_USE.md",
    "docs/PRESETS.md",
    "docs/RATING.md",
    "docs/SCHEMA.md",
    "docs/SE_COMPATIBILITY.md",
    "docs/SOLVER.md",
    "docs/STATE.md",
    "docs/TECHNIQUES.md",
    "examples",
    "LICENSE",
    "SECURITY.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    }
  },
  "bin": {
    "sudoku": "./dist/src/cli/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --pretty false",
    "clean": "node -e \"import('node:fs').then((fs)=>fs.rmSync('dist',{recursive:true,force:true}))\"",
    "audit:reference": "npm run build && node scripts/audit-reference-techniques.mjs && node scripts/audit-reference-rating-corpus.mjs",
    "audit:coverage": "npm run build && node scripts/audit-reference-coverage.mjs",
    "audit:forcing-evidence": "npm run build && node scripts/audit-forcing-branch-evidence.mjs",
    "audit:forcing-smoke": "npm run build && node scripts/audit-forcing-smoke-evidence.mjs",
    "audit:bug-evidence": "npm run build && node scripts/audit-bug-graph-evidence.mjs",
    "audit:fish-evidence": "npm run build && node scripts/audit-fish-evidence.mjs",
    "audit:canonical-equivalence": "npm run build && node scripts/audit-canonical-equivalence.mjs",
    "audit:canonical-equivalence:release": "npm run audit:canonical-equivalence -- --max-rows 8 --transforms-per-row 2 --json",
    "audit:canonical-equivalence:full": "npm run audit:canonical-equivalence -- --max-rows 68 --transforms-per-row 6 --json",
    "audit:uniqueness-evidence": "npm run build && node scripts/audit-uniqueness-evidence.mjs",
    "audit:technique-matrix": "npm run build && node scripts/audit-reference-coverage.mjs --markdown-output docs/TECHNIQUE_AUDIT_MATRIX.md",
    "audit:technique-priority": "npm run build && node scripts/audit-technique-priority.mjs",
    "audit:stable": "npm run build && node scripts/audit-stable-puzzles.mjs",
    "analyze:package-size": "node scripts/analyze-package-size.mjs",
    "benchmark:candidate-pool": "npm run build && node scripts/benchmark-candidate-pool.mjs",
    "benchmark:canonical": "npm run build && node scripts/benchmark-canonical.mjs",
    "benchmark:generator-diagnostics": "npm run build && node scripts/benchmark-generator-diagnostics.mjs",
    "benchmark:generator-targets": "npm run build && node scripts/benchmark-generator-targets.mjs",
    "benchmark:uniqueness": "npm run build && node scripts/benchmark-uniqueness.mjs",
    "examples:typecheck": "tsc -p tsconfig.examples.json --noEmit --pretty false",
    "find:reference-candidates": "npm run build && node scripts/find-reference-rating-candidates.mjs",
    "synthesize:reference-candidates": "npm run build && node scripts/synthesize-reference-rating-candidates.mjs",
    "pack:dry-run": "npm pack --dry-run --cache ./.npm-cache",
    "prepack": "npm run clean && npm run build",
    "prepublishOnly": "npm run verify",
    "smoke:cli": "npm run build && node scripts/smoke-cli.mjs",
    "smoke:dist": "npm run build && node -e \"import('./dist/src/index.js').then((m)=>{ if (typeof m.parsePuzzle !== 'function') throw new Error('parsePuzzle missing'); console.log('dist smoke passed'); })\"",
    "smoke:pack": "npm run build && node scripts/smoke-packed-package.mjs",
    "verify": "npm run typecheck && npm test && npm run examples:typecheck && npm run audit:reference && npm run smoke:dist && npm run smoke:cli && npm run pack:dry-run && npm run smoke:pack",
    "verify:coverage": "npm run audit:coverage && npm run audit:forcing-evidence && npm run audit:forcing-smoke && npm run audit:bug-evidence && npm run audit:fish-evidence && npm run audit:uniqueness-evidence",
    "verify:release": "npm run typecheck && npm test && npm run test:slow && npm run examples:typecheck && npm run audit:canonical-equivalence:release && npm run smoke:dist && npm run smoke:cli && npm run pack:dry-run && npm run smoke:pack && node scripts/verify-release.mjs",
    "verify:release:canonical-full": "node scripts/verify-release-canonical-full.mjs",
    "test": "tsc -p tsconfig.json --pretty false && node dist/tests/run-tests.js",
    "test:slow": "tsc -p tsconfig.json --pretty false && node -e \"process.env.CLASSIC9_TEST_PROFILE='slow'; import('./dist/tests/run-tests.js')\"",
    "test:full": "tsc -p tsconfig.json --pretty false && node -e \"process.env.CLASSIC9_TEST_PROFILE='full'; import('./dist/tests/run-tests.js')\"",
    "typecheck": "tsc -p tsconfig.json --noEmit --pretty false"
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "typescript": "^5.9.3"
  }
}
